<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="apod_wallpaper.WinUI.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MaxWidth="360"
            Spacing="18">
            <Border
                Width="82"
                Height="82"
                HorizontalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18">
                <FontIcon
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Glyph="&#xE7C3;"
                    FontSize="34"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            </Border>

            <StackPanel HorizontalAlignment="Center" Spacing="4">
                <TextBlock HorizontalAlignment="Center" FontSize="30" FontWeight="SemiBold" Text="APOD Wallpaper" />
                <TextBlock x:Name="VersionTextBlock" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Loading version..." />
                <TextBlock x:Name="PackageTextBlock" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Loading package..." TextWrapping="Wrap" TextAlignment="Center" />
            </StackPanel>

            <Border Width="48" Height="1" HorizontalAlignment="Center" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Spacing="10">
                <Button Click="ProjectRepositoryButton_Click" HorizontalContentAlignment="Left" Content="GitHub Repository" />
                <Button Click="SupportButton_Click" HorizontalContentAlignment="Left" Content="Official Website" />
                <Button Click="PrivacyButton_Click" HorizontalContentAlignment="Left" Content="Contact Support" />
                <Button Click="LicenseButton_Click" HorizontalContentAlignment="Left" Content="License Agreement" />
                <Button Click="ThirdPartyNoticesButton_Click" HorizontalContentAlignment="Left" Content="Third-party Notices" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,16,0,0" Spacing="4">
            <TextBlock HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="© 2026 APOD Wallpaper. All rights reserved." />
            <TextBlock HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Data provided by NASA API." />
        </StackPanel>

        <InfoBar
            x:Name="AboutStatusBar"
            Visibility="Collapsed"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="Product info" />
    </Grid>
</Page>
