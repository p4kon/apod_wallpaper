<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="apod_wallpaper.WinUI.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="6">
            <TextBlock FontSize="30" FontWeight="SemiBold" Text="Settings" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Manage application behavior and wallpaper preferences."
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="760" Spacing="18">
                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Start with Windows" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Automatically launch APOD Wallpaper in the background." TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="StartWithWindowsToggle" Grid.Column="1" VerticalAlignment="Center" Toggled="StartWithWindowsToggle_Toggled" />
                        </Grid>

                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Close behavior" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Choose what happens when you click the window close button." TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox
                                x:Name="CloseBehaviorComboBox"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                SelectionChanged="CloseBehaviorComboBox_SelectionChanged">
                                <ComboBoxItem Content="Hide to tray" Tag="hide" />
                                <ComboBoxItem Content="Exit application" Tag="exit" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Auto-check today's APOD" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Periodically check NASA for new images and apply them automatically." TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="AutoCheckToggle" Grid.Column="1" VerticalAlignment="Center" Toggled="AutoCheckToggle_Toggled" />
                        </Grid>

                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <StackPanel Spacing="10">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Wallpaper style" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Choose how the selected image should fit your screen." TextWrapping="Wrap" />
                            <ComboBox
                                x:Name="WallpaperStyleComboBox"
                                SelectionChanged="WallpaperStyleComboBox_SelectionChanged" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <StackPanel Spacing="14">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Download folder" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="ImagesDirectoryTextBox"
                                Grid.Column="0"
                                PlaceholderText="Folder for downloaded APOD images"
                                LostFocus="ImagesDirectoryTextBox_LostFocus"
                                KeyDown="ImagesDirectoryTextBox_KeyDown" />
                            <Button
                                x:Name="BrowseImagesFolderButton"
                                Grid.Column="1"
                                Click="BrowseImagesFolderButton_Click"
                                Content="Browse" />
                            <Button
                                x:Name="OpenImagesFolderButton"
                                Grid.Column="2"
                                Click="OpenImagesFolderButton_Click"
                                Content="Open" />
                        </Grid>
                        <TextBlock
                            x:Name="ImagesDirectoryHintText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Changes are saved through the backend as soon as the field is committed."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="NASA API Key" />
                            <TextBlock
                                x:Name="ApiKeySummaryText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Configure a personal key to avoid rate limiting issues."
                                TextWrapping="Wrap" />
                            <Border
                                x:Name="ApiKeyStateBadge"
                                HorizontalAlignment="Left"
                                Padding="10,6"
                                CornerRadius="999">
                                <TextBlock x:Name="ApiKeyStateText" FontWeight="SemiBold" Text="Checking..." />
                            </Border>
                        </StackPanel>

                        <Button
                            x:Name="ConfigureApiKeyButton"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Click="ConfigureApiKeyButton_Click"
                            Content="Configure"
                            Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Visibility="Collapsed">
            <InfoBar
                x:Name="SettingsStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Loading settings" />
            <TextBox
                x:Name="ApiKeyTextBox"
                PlaceholderText="Paste NASA API key"
                LostFocus="ApiKeyTextBox_LostFocus"
                KeyDown="ApiKeyTextBox_KeyDown" />
            <Button
                x:Name="GetApiKeyButton"
                Click="GetApiKeyButton_Click"
                Content="Get API key" />
            <ToggleSwitch
                x:Name="CloseToTrayToggle"
                Header="Clicking X hides to tray instead of exiting"
                Toggled="CloseToTrayToggle_Toggled" />
        </StackPanel>
    </Grid>
</Page>
