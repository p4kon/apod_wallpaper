<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="apod_wallpaper.WinUI.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid MaxWidth="980" Padding="24" HorizontalAlignment="Center" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Settings" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="These controls save through the shared backend. The UI edits settings, but it does not know where they are stored."
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                x:Name="SettingsStatusBar"
                Grid.Row="1"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Loading settings" />

            <Grid Grid.Row="2" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="NASA API key" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="A personal key enables richer calendar warmup and avoids the shared DEMO_KEY limits."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                x:Name="ApiKeyTextBox"
                                Grid.Row="0"
                                PlaceholderText="Paste NASA API key"
                                LostFocus="ApiKeyTextBox_LostFocus"
                                KeyDown="ApiKeyTextBox_KeyDown" />

                            <Button
                                x:Name="GetApiKeyButton"
                                Grid.Row="0"
                                Grid.Column="1"
                                Click="GetApiKeyButton_Click"
                                Content="Get API key" />

                            <Border
                                x:Name="ApiKeyStateBadge"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Padding="12,8"
                                CornerRadius="12">
                                <TextBlock x:Name="ApiKeyStateText" FontWeight="SemiBold" Text="Checking..." />
                            </Border>

                            <TextBlock
                                x:Name="ApiKeyHelpText"
                                Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="If the NASA site does not open in your region, VPN may be required."
                                TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Behavior" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Host-level behavior stays simple: tray, startup, and automatic checks."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <ToggleSwitch
                            x:Name="AutoCheckToggle"
                            Header="Auto-check for latest APOD"
                            Toggled="AutoCheckToggle_Toggled" />

                        <ToggleSwitch
                            x:Name="StartWithWindowsToggle"
                            Header="Start with Windows"
                            Toggled="StartWithWindowsToggle_Toggled" />

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Margin="0,-10,0,0"
                            Text="The packaged host already stores this through the backend. Full StartupTask integration is still being finalized."
                            TextWrapping="Wrap" />

                        <ToggleSwitch
                            x:Name="TrayDoubleClickToggle"
                            Header="Double-click tray icon applies latest APOD"
                            Toggled="TrayDoubleClickToggle_Toggled" />

                        <ToggleSwitch
                            x:Name="CloseToTrayToggle"
                            Header="Clicking X hides to tray instead of exiting"
                            Toggled="CloseToTrayToggle_Toggled" />

                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="Wallpaper mode" />
                            <ComboBox
                                x:Name="WallpaperStyleComboBox"
                                SelectionChanged="WallpaperStyleComboBox_SelectionChanged" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.ColumnSpan="2"
                    Grid.Row="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Images folder" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="The backend remains the source of truth for the active images directory and storage layout."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                x:Name="ImagesDirectoryTextBox"
                                Grid.Row="0"
                                PlaceholderText="Folder for downloaded APOD images"
                                LostFocus="ImagesDirectoryTextBox_LostFocus"
                                KeyDown="ImagesDirectoryTextBox_KeyDown" />

                            <Button
                                x:Name="BrowseImagesFolderButton"
                                Grid.Row="0"
                                Grid.Column="1"
                                Click="BrowseImagesFolderButton_Click"
                                Content="Browse" />

                            <Button
                                x:Name="OpenImagesFolderButton"
                                Grid.Row="0"
                                Grid.Column="2"
                                Click="OpenImagesFolderButton_Click"
                                Content="Open" />

                            <TextBlock
                                x:Name="ImagesDirectoryHintText"
                                Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Changes are saved through the backend as soon as the field is committed."
                                TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
