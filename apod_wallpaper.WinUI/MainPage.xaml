<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="apod_wallpaper.WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="StatusBar"
            Grid.Row="0"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Visibility="Collapsed"
            Title="Starting backend" />

        <Grid Grid.Row="1" Margin="8,0,8,18" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="36"
                Height="36"
                Padding="0"
                Click="PreviousMonthButton_Click"
                Background="Transparent"
                BorderBrush="Transparent">
                <SymbolIcon Symbol="Back" />
            </Button>

            <TextBlock
                x:Name="VisibleMonthText"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="28"
                FontWeight="SemiBold"
                Text="Loading month..." />

            <Button
                Grid.Column="2"
                Width="36"
                Height="36"
                Padding="0"
                Click="NextMonthButton_Click"
                Background="Transparent"
                BorderBrush="Transparent">
                <SymbolIcon Symbol="Forward" />
            </Button>
        </Grid>

        <Grid Grid.Row="2" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="22,18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="22">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="WeekdayHeaderGrid" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Mo" />
                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Tu" />
                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="We" />
                        <TextBlock Grid.Column="3" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Th" />
                        <TextBlock Grid.Column="4" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Fr" />
                        <TextBlock Grid.Column="5" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Sa" />
                        <TextBlock Grid.Column="6" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Su" />
                    </Grid>

                    <Grid x:Name="CalendarDaysGrid" Grid.Row="1" ColumnSpacing="8" RowSpacing="8" />
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Padding="16,10"
                Background="Transparent"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="22">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#1FB57A" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Local" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#4E86F5" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Available" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#E85B5B" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Video" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#CBD5E1" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Unchecked" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="PreviewSurfaceBorder"
                    Grid.Column="0"
                    MinHeight="188"
                    CornerRadius="20,0,0,20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Image
                            x:Name="PreviewImage"
                            ImageFailed="PreviewImage_ImageFailed"
                            ImageOpened="PreviewImage_ImageOpened"
                            Stretch="UniformToFill"
                            Visibility="Collapsed" />

                        <ProgressRing
                            x:Name="PreviewProgressRing"
                            Width="48"
                            Height="48"
                            IsActive="False"
                            Visibility="Collapsed" />

                        <StackPanel
                            x:Name="PreviewPlaceholderPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="220"
                            Spacing="10">
                            <FontIcon
                                x:Name="PreviewPlaceholderIcon"
                                HorizontalAlignment="Center"
                                Glyph="&#xE91B;"
                                FontSize="34"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                x:Name="PreviewPlaceholderTitleText"
                                HorizontalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Preview not loaded" />
                            <TextBlock
                                x:Name="PreviewPlaceholderText"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Choose a date in the calendar to load APOD preview."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="18"
                    CornerRadius="0,20,20,0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,1,1,1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="8,4"
                            HorizontalAlignment="Left"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <TextBlock
                                x:Name="RequestedDateText"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Text="Not loaded" />
                        </Border>

                        <TextBlock
                            x:Name="PreviewTitleText"
                            Grid.Row="1"
                            Margin="0,14,0,0"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="Select a date" />

                        <TextBlock
                            x:Name="PreviewBodyText"
                            Grid.Row="2"
                            Margin="0,12,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="The preview area will show the selected APOD image. Unsupported dates and not-yet-published days will use placeholders instead of noisy text."
                            TextWrapping="WrapWholeWords" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,4,0,0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="DownloadOnlyButton"
                    Grid.Column="0"
                    Height="44"
                    Click="DownloadOnlyButton_Click"
                    Content="Download" />

                <Button
                    x:Name="DownloadAndApplyButton"
                    Grid.Column="1"
                    Height="44"
                    Click="DownloadAndApplyButton_Click"
                    Content="Apply"
                    Style="{StaticResource AccentButtonStyle}" />

                <ProgressRing
                    x:Name="ActionProgressRing"
                    Grid.Column="2"
                    Width="24"
                    Height="24"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    IsActive="False"
                    Visibility="Collapsed" />
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3" Visibility="Collapsed">
            <InfoBar
                x:Name="MonthStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Month status idle" />
            <InfoBar
                x:Name="PreviewStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Preview idle" />
            <InfoBar
                x:Name="ActionStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Actions idle" />
            <TextBlock x:Name="SelectedDateText" Text="No date selected yet" />
            <Button x:Name="ReloadPreviewButton" Click="ReloadPreviewButton_Click" Content="Reload preview" />
            <Button x:Name="OpenNasaPageButton" Click="OpenNasaPageButton_Click" Content="Open NASA page" />
            <ComboBox
                x:Name="WallpaperStyleComboBox"
                MinWidth="180"
                SelectionChanged="WallpaperStyleComboBox_SelectionChanged" />
            <Button x:Name="ApplyLatestButton" Click="ApplyLatestButton_Click" Content="Apply latest" />
            <TextBlock x:Name="ResolvedDateText" Text="Not loaded" />
            <TextBlock x:Name="PreviewWorkflowStatusText" Text="Idle" />
            <TextBlock x:Name="PreviewSourceText" Text="Unknown" />
            <TextBlock x:Name="PreviewLocationText" Text="Not loaded" />
            <TextBlock x:Name="PreviewMessageText" Text="Waiting for request." />
            <TextBlock x:Name="PreferredDateText" Text="Loading..." />
            <TextBlock x:Name="WallpaperStyleText" Text="Loading..." />
            <TextBlock x:Name="AutoCheckText" Text="Loading..." />
            <TextBlock x:Name="StartupText" Text="Loading..." />
            <TextBlock x:Name="ApiKeyStateText" Text="Loading..." />
            <TextBlock x:Name="ImagesDirectoryText" Text="Loading..." />
            <TextBlock x:Name="StorageModeText" Text="Loading..." />
            <TextBlock x:Name="LocalImageIndexText" Text="Loading..." />
            <TextBlock x:Name="TrayActionText" Text="Loading..." />
            <TextBlock x:Name="SnapshotSummaryText" Text="Loading backend state..." />
            <TextBlock x:Name="TrayStatusText" Text="Tray spike not initialized yet." />
        </StackPanel>
    </Grid>
</Page>
