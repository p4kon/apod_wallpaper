<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="apod_wallpaper.WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto">
    <Grid Padding="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="StatusBar"
            Grid.Row="0"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Visibility="Collapsed"
            Title="Starting backend" />

        <Grid Grid.Row="1" Margin="4,0,4,12">
            <Grid
                Width="280"
                HorizontalAlignment="Center"
                ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    Padding="0"
                    Click="PreviousMonthButton_Click"
                    Background="Transparent"
                    BorderBrush="Transparent">
                    <SymbolIcon Symbol="Back" />
                </Button>

                <TextBlock
                    x:Name="VisibleMonthText"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="Loading month..." />

                <Button
                    Grid.Column="2"
                    Width="36"
                    Height="36"
                    Padding="0"
                    Click="NextMonthButton_Click"
                    Background="Transparent"
                    BorderBrush="Transparent">
                    <SymbolIcon Symbol="Forward" />
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="22">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="WeekdayHeaderGrid" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Mon" />
                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Tue" />
                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Wed" />
                        <TextBlock Grid.Column="3" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Thu" />
                        <TextBlock Grid.Column="4" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Fri" />
                        <TextBlock Grid.Column="5" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Sat" />
                        <TextBlock Grid.Column="6" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Sun" />
                    </Grid>

                    <Grid x:Name="CalendarDaysGrid" Grid.Row="1" ColumnSpacing="6" RowSpacing="6" />
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Padding="10,8"
                Background="Transparent"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#1FB57A" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Local" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#4E86F5" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Available" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#E85B5B" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Video" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="12" Height="12" CornerRadius="6" Background="#CBD5E1" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Unchecked" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="0" Height="188">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.92*" />
                    <ColumnDefinition Width="1.08*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="PreviewSurfaceBorder"
                    Grid.Column="0"
                    CornerRadius="20,0,0,20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid x:Name="PreviewImageHost" SizeChanged="PreviewImageHost_SizeChanged">
                        <Grid
                            x:Name="PreviewImageFrame"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                            <Rectangle
                                x:Name="PreviewImageSurface"
                                RadiusX="20"
                                RadiusY="20">
                                <Rectangle.Fill>
                                    <ImageBrush
                                        x:Name="PreviewImageBrush"
                                        AlignmentX="Center"
                                        AlignmentY="Center"
                                        Stretch="Fill" />
                                </Rectangle.Fill>
                            </Rectangle>

                            <Grid IsHitTestVisible="False">
                                <Rectangle HorizontalAlignment="Left" Width="14" RadiusX="20" RadiusY="20">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#20FFFFFF" Offset="0" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle HorizontalAlignment="Right" Width="14" RadiusX="20" RadiusY="20">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                                            <GradientStop Color="#20FFFFFF" Offset="0" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle VerticalAlignment="Top" Height="14" RadiusX="20" RadiusY="20">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#18FFFFFF" Offset="0" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle VerticalAlignment="Bottom" Height="14" RadiusX="20" RadiusY="20">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                            <GradientStop Color="#18FFFFFF" Offset="0" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </Grid>

                        <ProgressRing
                            x:Name="PreviewProgressRing"
                            Width="48"
                            Height="48"
                            IsActive="False"
                            Visibility="Collapsed" />

                        <StackPanel
                            x:Name="PreviewPlaceholderPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="220"
                            Spacing="10">
                            <FontIcon
                                x:Name="PreviewPlaceholderIcon"
                                HorizontalAlignment="Center"
                                Glyph="&#xE91B;"
                                FontSize="34"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                x:Name="PreviewPlaceholderTitleText"
                                HorizontalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Preview not loaded" />
                            <TextBlock
                                x:Name="PreviewPlaceholderText"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Choose a date in the calendar to load APOD preview."
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="18,14,18,18"
                    CornerRadius="0,20,20,0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,1,1,1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            x:Name="PreviewTitleText"
                            Text="Explanation"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <ScrollViewer
                            x:Name="PreviewBodyScrollViewer"
                            Grid.Row="1"
                            Margin="0,6,0,0"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollMode="Enabled"
                            VerticalScrollBarVisibility="Auto">
                            <TextBlock
                                x:Name="PreviewBodyText"
                                Width="{Binding ElementName=PreviewBodyScrollViewer, Path=ActualWidth}"
                                FontSize="14"
                                LineHeight="21"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="The preview area will show the selected APOD image. Unsupported dates and not-yet-published days will use placeholders instead of noisy text."
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid
                Grid.Row="3"
                Margin="0,6,0,0"
                HorizontalAlignment="Center"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="206" />
                    <ColumnDefinition Width="206" />
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="22" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="NasaPageButton"
                    Grid.Column="0"
                    Width="88"
                    Height="42"
                    Click="OpenNasaPageButton_Click"
                    Content="NASA" />

                <Button
                    x:Name="DownloadOnlyButton"
                    Grid.Column="1"
                    Width="206"
                    Height="42"
                    Click="DownloadOnlyButton_Click"
                    Content="Download" />

                <Button
                    x:Name="DownloadAndApplyButton"
                    Grid.Column="2"
                    Width="206"
                    Height="42"
                    Click="DownloadAndApplyButton_Click"
                    Content="Apply"
                    Style="{StaticResource AccentButtonStyle}" />

                <ToggleButton
                    x:Name="AutoRefreshToggleButton"
                    Grid.Column="3"
                    Width="88"
                    Height="42"
                    Checked="AutoRefreshToggleButton_Checked"
                    Unchecked="AutoRefreshToggleButton_Unchecked"
                    Content="Auto" />

                <ProgressRing
                    x:Name="ActionProgressRing"
                    Grid.Column="4"
                    Width="22"
                    Height="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsActive="False"
                    Opacity="0" />
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3" Visibility="Collapsed">
            <InfoBar
                x:Name="MonthStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Month status idle" />
            <InfoBar
                x:Name="PreviewStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Preview idle" />
            <InfoBar
                x:Name="ActionStatusBar"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="Actions idle" />
            <TextBlock x:Name="SelectedDateText" Text="No date selected yet" />
            <Button x:Name="ReloadPreviewButton" Click="ReloadPreviewButton_Click" Content="Reload preview" />
            <Button x:Name="OpenNasaPageButton" Click="OpenNasaPageButton_Click" Content="Open NASA page" />
            <ComboBox
                x:Name="WallpaperStyleComboBox"
                MinWidth="180"
                SelectionChanged="WallpaperStyleComboBox_SelectionChanged" />
            <Button x:Name="ApplyLatestButton" Click="ApplyLatestButton_Click" Content="Apply latest" />
            <TextBlock x:Name="ResolvedDateText" Text="Not loaded" />
            <TextBlock x:Name="PreviewWorkflowStatusText" Text="Idle" />
            <TextBlock x:Name="PreviewSourceText" Text="Unknown" />
            <TextBlock x:Name="PreviewLocationText" Text="Not loaded" />
            <TextBlock x:Name="PreviewMessageText" Text="Waiting for request." />
            <TextBlock x:Name="PreferredDateText" Text="Loading..." />
            <TextBlock x:Name="WallpaperStyleText" Text="Loading..." />
            <TextBlock x:Name="AutoCheckText" Text="Loading..." />
            <TextBlock x:Name="StartupText" Text="Loading..." />
            <TextBlock x:Name="ApiKeyStateText" Text="Loading..." />
            <TextBlock x:Name="ImagesDirectoryText" Text="Loading..." />
            <TextBlock x:Name="StorageModeText" Text="Loading..." />
            <TextBlock x:Name="LocalImageIndexText" Text="Loading..." />
            <TextBlock x:Name="TrayActionText" Text="Loading..." />
            <TextBlock x:Name="SnapshotSummaryText" Text="Loading backend state..." />
            <TextBlock x:Name="TrayStatusText" Text="Tray spike not initialized yet." />
        </StackPanel>

    </Grid>
    </ScrollViewer>
</Page>
